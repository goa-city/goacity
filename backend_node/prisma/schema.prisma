generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id            Int       @id @default(autoincrement())
  email         String?   @unique @db.VarChar(255)
  phone         String?   @unique @db.VarChar(50)
  dob           DateTime? @db.Date
  gender        String?   @db.VarChar(50)
  location      String?   @db.VarChar(255)
  role          String?   @default("member") @db.VarChar(50)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  password_hash String?
  is_onboarded  Int?      @default(0) @db.SmallInt
  bio           String?
  profile_photo String?   @db.VarChar(255)
  linkedin_url  String?   @db.VarChar(255)
  intro_video   String?   @db.VarChar(255)
  village       String?   @db.VarChar(100)
  address       String?
  age           Int?
  first_name    String?   @db.VarChar(255)
  last_name     String?   @db.VarChar(255)

  city_id       Int?      @default(1)
  city          City?     @relation(fields: [city_id], references: [id])

  streams         StreamMember[]
  posts           Post[]
  responses       FormResponse[]
  profiles        MemberProfile[]
  businesses      Business[]
  stewardshipLogs StewardshipLog[]
  mentorshipsAsMentor MentorshipRelation[] @relation("MentorshipMentor")
  mentorshipsAsMentee MentorshipRelation[] @relation("MentorshipMentee")
  incubatorIdeas  IncubatorIdea[] 
  ideaFeedbacks   IdeaFeedback[] 
  services        MemberService[]
  collabsMade     CollaborationRequest[] @relation("CollabRequester")
  collabsReceived CollaborationRequest[] @relation("CollabProvider")

  @@map("members")
}

model City {
  id                Int       @id @default(autoincrement())
  name              String    @unique @db.VarChar(255)
  slug              String    @unique @db.VarChar(100)
  domain            String?   @unique @db.VarChar(255)
  timezone          String?   @default("Asia/Kolkata") @db.VarChar(100)
  email_from_name   String?   @db.VarChar(255)
  email_from_addr   String?   @db.VarChar(255)
  theme_config      Json?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)

  members           Member[]
  admins            Admin[]
  streams           Stream[]
  posts             Post[]
  forms             forms[]
  meetings          meetings[]
  jobs              jobs[]
  resources         resources[]
  pages             Page[]
  email_templates   EmailTemplate[]
  form_responses    FormResponse[]

  @@map("cities")
}

model Admin {
  id            Int       @id @default(autoincrement())
  full_name     String?   @db.VarChar(255)
  email         String?   @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          String?   @default("admin") @db.VarChar(50)
  is_super_admin Boolean  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  city_id       Int?      @default(1)
  city          City?     @relation(fields: [city_id], references: [id])

  @@map("admins")
}

model Stream {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?
  color       String?   @default("#6366f1") @db.VarChar(7)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  form_id     Int?

  city_id     Int?      @default(1)
  city        City?     @relation(fields: [city_id], references: [id])

  members     StreamMember[]

  @@map("streams")
}

model StreamMember {
  stream_id Int
  user_id   Int

  stream    Stream @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  user      Member @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([stream_id, user_id])
  @@map("stream_members")
}

model Otp {
  id             Int       @id @default(autoincrement())
  email_or_phone String    @db.VarChar(255)
  otp_code       String    @db.VarChar(10)
  expires_at     DateTime  @db.Timestamp(6)
  attempts       Int?      @default(0)
  created_at     DateTime? @default(now()) @db.Timestamp(6)

  @@map("otp_table")
}

model Post {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  user       Member? @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content    String?
  media_url  String?   @db.VarChar(255)
  media_type String?   @default("none") @db.VarChar(50)
  link_title String?   @db.VarChar(255)
  link_desc  String?   @db.VarChar(255)
  link_image String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  city_id    Int?      @default(1)
  city       City?     @relation(fields: [city_id], references: [id])

  @@map("posts")
}

model FormResponse {
  id           Int       @id @default(autoincrement())
  form_id      Int?
  user_id      Int?
  meeting_id   Int?
  user         Member?   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  form         forms?    @relation(fields: [form_id], references: [id], onDelete: Cascade)
  answers      FormAnswer[]
  submitted_at DateTime? @default(now()) @db.Timestamp(6)
  status       String?   @default("draft") @db.VarChar(50)
  
  city_id      Int?      @default(1)
  city         City?     @relation(fields: [city_id], references: [id])

  @@map("form_responses")
}

model MemberProfile {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  user          Member? @relation(fields: [user_id], references: [id], onDelete: Cascade)
  profile_key   String    @db.VarChar(100)
  profile_value String?
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  @@map("member_profiles")
}

model Business {
  id                 Int     @id @default(autoincrement())
  user_id            Int?
  user               Member? @relation(fields: [user_id], references: [id], onDelete: Cascade)
  business_name      String? @db.VarChar(255)
  business_type      String? @db.VarChar(100)
  industry           String? @db.VarChar(100)
  years_in_operation Int?
  employees_count    Int?
  website            String? @db.VarChar(255)
  summary            String?

  @@map("businesses")
}

model attendance {
  id         Int       @id @default(autoincrement())
  meeting_id Int?
  user_id    Int?
  status     String?   @default("absent") @db.VarChar(50)
  marked_by  Int?
  marked_at  DateTime? @default(now()) @db.Timestamp(6)
}

model FormAnswer {
  id           Int       @id @default(autoincrement())
  response_id  Int?
  response     FormResponse? @relation(fields: [response_id], references: [id], onDelete: Cascade)
  field_key    String    @db.VarChar(100)
  answer_value String?

  @@map("form_answers")
}

model FormField {
  id           Int     @id @default(autoincrement())
  form_id      Int?
  form         forms?  @relation(fields: [form_id], references: [id], onDelete: Cascade)
  field_key    String  @db.VarChar(100)
  field_type   String  @db.VarChar(50)
  label        String? @db.VarChar(255)
  subtitle     String?
  placeholder  String? @db.VarChar(255)
  options      Json?
  is_required  Int?    @default(0) @db.SmallInt
  is_optional  Int?    @default(0) @db.SmallInt
  is_profile   Int?    @default(0) @db.SmallInt
  sort_order   Int?    @default(0)
  section      String? @db.VarChar(100)
  conditions   Json?
  group_fields Json?
  button_text  String? @default("Next") @db.VarChar(50)

  @@map("form_fields")
}

model forms {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)
  title       String    @db.VarChar(255)
  description String?
  is_active   Int?      @default(1) @db.SmallInt
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  created_by  Int?

  fields      FormField[]
  responses   FormResponse[]

  city_id     Int?      @default(1)
  city        City?     @relation(fields: [city_id], references: [id])
}

model jobs {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  company       String    @db.VarChar(255)
  location      String    @db.VarChar(255)
  category      String?   @db.VarChar(100)
  type          String?   @default("Full Time") @db.VarChar(50)
  description   String?
  url           String?   @db.VarChar(500)
  contact_email String?   @db.VarChar(255)
  posted_by     Int?
  status        String?   @default("pending") @db.VarChar(50)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  city_id       Int?      @default(1)
  city          City?     @relation(fields: [city_id], references: [id])
}

model meeting_responses {
  id             Int       @id @default(autoincrement())
  meeting_id     Int?
  user_id        Int?
  rsvp_status    String?   @default("none") @db.VarChar(50)
  checked_in     Int?      @default(0) @db.SmallInt
  payment_status String?   @default("pending") @db.VarChar(50)
  paid_amount    Decimal?  @default(0.00) @db.Decimal(10, 2)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
}

model meetings {
  id               Int       @id @default(autoincrement())
  title            String    @db.VarChar(255)
  description      String?
  meeting_date     DateTime? @db.Date
  start_time       DateTime? @db.Time(6)
  end_time         DateTime? @db.Time(6)
  location_name    String?   @db.VarChar(255)
  map_link         String?
  is_paid          Int?      @default(0) @db.SmallInt
  payment_qr_image String?   @db.VarChar(255)
  feedback_form_id Int?
  archived         Int?      @default(0) @db.SmallInt
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  stream_id        Int?
  payment_amount   Decimal?  @default(0.00) @db.Decimal(10, 2)
  recap_content    String?   @db.Text
  zoom_link        String?   @db.VarChar(500)
  google_event_id  String?   @db.VarChar(255)
  
  city_id          Int?      @default(1)
  city             City?     @relation(fields: [city_id], references: [id])

  resources        MeetingResource[]
}

model MeetingResource {
  id          Int      @id @default(autoincrement())
  meeting_id  Int
  title       String   @db.VarChar(255)
  url         String   @db.VarChar(500)
  type        String?  @default("link") @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  meeting     meetings @relation(fields: [meeting_id], references: [id], onDelete: Cascade)

  @@map("meeting_resources")
}

model needs {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  need_type   String?   @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model offers {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  offer_type  String?   @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model post_likes {
  id         Int       @id @default(autoincrement())
  post_id    Int?
  user_id    Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model resources {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  category     String    @db.VarChar(100)
  author       String    @db.VarChar(255)
  url          String?   @db.VarChar(500)
  image_url    String?   @db.VarChar(500)
  file_path    String?   @db.VarChar(500)
  file_name    String?   @db.VarChar(255)
  description  String?
  content      String?
  submitted_by Int?
  status       String?   @default("pending") @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  city_id      Int?      @default(1)
  city         City?     @relation(fields: [city_id], references: [id])
}

model skills {
  id         Int     @id @default(autoincrement())
  skill_name String? @db.VarChar(100)
}

model VerificationOrg {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  org_type   String    @db.VarChar(100)
  status     String    @default("Active") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("stewardship_orgs")
}

model StewardshipLog {
  id               Int       @id @default(autoincrement())
  user_id          Int
  user             Member    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type             String    @db.VarChar(50) // "Financial" | "Skill"
  recipient_id     Int?      // For orgs or members
  amount           Decimal?  @db.Decimal(10, 2)
  hours            Decimal?  @db.Decimal(10, 2)
  date             DateTime? @db.Date
  skill_category   String?   @db.VarChar(100)
  status           String    @default("Pending") @db.VarChar(50) // "Pending" | "Verified"
  impact_note      String?
  impact_image_url String?   @db.VarChar(255)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  @@map("stewardship_logs")
}

model MentorshipRelation {
  id             String    @id @default(uuid())
  mentor_id      Int
  mentee_id      Int
  status         String    @default("Requested") @db.VarChar(50) 
  type           String    @db.VarChar(50) 
  focus_area     String?   @db.VarChar(255)
  goals_json     Json?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  mentor         Member    @relation("MentorshipMentor", fields: [mentor_id], references: [id], onDelete: Cascade)
  mentee         Member    @relation("MentorshipMentee", fields: [mentee_id], references: [id], onDelete: Cascade)

  @@map("mentorship_relations")
}

model IncubatorIdea {
  id                String    @id @default(uuid())
  founder_id        Int
  title             String    @db.VarChar(255)
  problem_statement String?
  vision_purpose    String?
  status            String    @default("Draft") @db.VarChar(50) // Draft, Submitted, Under_Review, Validated, Launched
  needs_json        Json?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)

  founder           Member    @relation(fields: [founder_id], references: [id], onDelete: Cascade)
  feedbacks         IdeaFeedback[]

  @@map("incubator_ideas")
}

model IdeaFeedback {
  id             String    @id @default(uuid())
  idea_id        String
  contributor_id Int
  comment        String?
  type           String    @db.VarChar(50) // Guidance, Validation, Resource_Link
  created_at     DateTime? @default(now()) @db.Timestamp(6)

  idea           IncubatorIdea @relation(fields: [idea_id], references: [id], onDelete: Cascade)
  contributor    Member        @relation(fields: [contributor_id], references: [id], onDelete: Cascade)

  @@map("idea_feedback")
}

model MemberService {
  id          String   @id @default(uuid())
  member_id   Int
  title       String   @db.VarChar(255)
  type        String   @db.VarChar(50) 
  description String?  
  status      String   @default("Active") @db.VarChar(50) 

  member      Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@map("member_services")
}

model CollaborationRequest {
  id           String    @id @default(uuid())
  requester_id Int
  provider_id  Int
  type         String    @db.VarChar(50) 
  description  String?   
  status       String    @default("Pending_Admin") @db.VarChar(50) 
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  requester    Member    @relation("CollabRequester", fields: [requester_id], references: [id], onDelete: Cascade)
  provider     Member    @relation("CollabProvider", fields: [provider_id], references: [id], onDelete: Cascade)

  @@map("collaboration_requests")
}

model Page {
  id         Int       @id @default(autoincrement())
  slug       String    @unique @db.VarChar(100)
  title      String    @db.VarChar(255)
  content    String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  city_id    Int?      @default(1)
  city       City?     @relation(fields: [city_id], references: [id])

  @@map("pages")
}

model EmailTemplate {
  id         Int       @id @default(autoincrement())
  title      String    @unique @db.VarChar(255) // For reference in code (slug/id)
  subject    String    @db.VarChar(255)
  message    String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  city_id    Int?      @default(1)
  city       City?     @relation(fields: [city_id], references: [id])

  @@map("email_templates")
}

